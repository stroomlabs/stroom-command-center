{
  "expo": {
    "name": "Stroom Command",
    "slug": "stroom-command-center",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "stroom-command",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0F14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stroomlabs.command",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Authenticate to access the Stroom Command Center"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.stroomlabs.command",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Authenticate to access the Stroom Command Center"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00A19B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "20985dd9-a6a9-440f-afb4-64ddb3b14ddd"
      }
    }
  }
}
